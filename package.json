{
    "name": "camel-scripts",
    "private": true,
    "version": "0.1.16",
    "type": "module",
    "pre-commit": [
        "upd"
    ],
    "scripts": {
        "prepare": "husky && node ./scripts/psrgen.js && node ./scripts/install.js",
        "upd": "node ./scripts/update.js",
        "cnt": "node ./scripts/cnt.js",
        "init": "node ./scripts/psrgen.js && node ./scripts/install.js",
        "psrgen": "node ./scripts/psrgen.js",
        "codegen": "node ./scripts/codegen.js",
        "check": "node ./scripts/check.js",
        "test": "node ./scripts/test.js",
        "test:all": "node ./scripts/test-all.js",
        "test:modules": "node ./scripts/test-all.js --modules",
        "test:run": "node ./scripts/test-all.js --run",
        "test:run:linear": "node ./scripts/test-all.js --run --suite linear",
        "test:run:nn": "node ./scripts/test-all.js --run --suite nn",
        "test:run:para": "node ./scripts/test-all.js --run --suite para",
        "config": "node ./scripts/config.js",
        "build": "node ./scripts/build.js",
        "debug": "node ./scripts/debug.js",
        "profile": "node ./scripts/profile.js",
        "out": "node ./scripts/collect-out.js",
        "out:debug": "node ./scripts/collect-out.js debug",
        "out:profile": "node ./scripts/collect-out.js profile",
        "perf:samply": "samply record camel ./test/perf/main.cml",
        "perf:record": "perf record -g camel ./test/perf/main.cml",
        "perf:report": "perf report",
        "perf:render": "perf record -g --call-graph dwarf camel ./test/perf/main.cml && hotspot ./perf.data",
        "clean": "node ./scripts/clean.js",
        "format": "node ./scripts/format.js",
        "setver": "node ./scripts/setver.js",
        "gitcnt": "node ./scripts/gitcnt.js",
        "code-stats": "python ./scripts/code_stats.py",
        "fix:vsc": "node ./scripts/fix.js vsc",
        "pypi:rollup": "node ./scripts/pypi-rollup.js",
        "pypi:upload": "python -m twine upload --repository testpypi dist/pypi/*",
        "pypi:upload:release": "python -m twine upload --repository pypi dist/pypi/*",
        "pypi:install": "pip install --index-url https://test.pypi.org/simple/ camel-lang",
        "gource": "gource -c 4 --frameless -f --title \"CAMEL\" --font-size 24 --hide progress --padding 1.2",
        "debugger:ui": "npm run dev --prefix tools/debugger/ui",
        "debugger:build": "npm run build --prefix tools/debugger/ui",
        "debugger:serve": "python tools/debugger/serve_ui.py"
    },
    "devDependencies": {
        "fs-extra": "^11.3.0",
        "husky": "^9.1.7",
        "iconv-lite": "^0.7.2",
        "ora": "^8.2.0",
        "sqlite3": "^5.1.7"
    }
}
