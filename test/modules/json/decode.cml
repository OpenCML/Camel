module main

import { encode, decode } from json

func main(): int sync {
    println("=== JSON decode tests ===")

    println("\n[1] decode string")
    let decStr = decode("\"hello\"") as string
    println("  decode('\"hello\"') =", decStr)

    println("\n[2] decode number")
    let decNum = decode("42") as int
    println("  decode('42') =", decNum)

    println("\n[3] decode array")
    let decArr = decode("[1,2,3]") as int[]
    println("  decode('[1,2,3]') =", decArr)

    println("\n[4] decode object")
    let decObj = decode("{\"a\":1,\"b\":\"x\"}") as { a: int, b: string }
    println("  decode('{\"a\":1,\"b\":\"x\"}') =", decObj)
    println("  .a =", decObj.a, ", .b =", decObj.b)

    println("\n[5] roundtrip struct")
    let orig = { id: 1, name: "test", vals: [10, 20] }
    let jsonStr = encode(orig)
    println("  encode(orig) =", jsonStr)
    let restored = decode(jsonStr) as { id: int, name: string, vals: int[] }
    println("  decode(...).id =", restored.id, ", .name =", restored.name, ", .vals =", restored.vals)

    println("\n=== JSON decode tests completed ===")
    return 0
}
