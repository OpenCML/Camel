module main

// 最简 python 模块测试
import { py_eval, py_call, py_wrap, py_unwrap, PyObject } from python

func main(): int sync {
    println("=== Python Module Basic Tests ===")

    println("\n[1] py_call('print', py_wrap('hello'))")
    py_call("print", py_wrap("hello"))

    println("\n[2] py_eval('1 + 2') -> py_unwrap as int")
    let r = py_unwrap(py_eval("1 + 2") as PyObject<int>)
    '  1 + 2 = {}'->format<r>->println

    println("\n=== Basic tests completed ===")
    return 0
}
