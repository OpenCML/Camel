module main

// time 模块基础测试
import { now, strftime } from time

func main(): int sync {
    println("=== Time Module Basic Tests ===")

    println("\n[1] now()")
    let t = now()
    println("  now =", t)

    println("\n[2] strftime(now(), '%Y-%m-%d')")
    let fmt = strftime(t, "%Y-%m-%d")
    println("  fmt =", fmt)

    println("\n=== Time tests completed ===")
    return 0
}
