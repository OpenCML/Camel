// mnist_py.cml - Softmax classifier with MNIST loaded via Python (no JSON file)

module mnist_py

import {
    Tensor, argmax, concat, exp, log, max, ones, range, reshape, shape, sum, transpose, zeros
} from tensor
import { py_import, py_call, py_wrap, py_unwrap, py_exec, py_attr, PyObject } from python
import { round } from math

let num_classes = 10

func broadcast_col_to(col: Tensor, k: int): Tensor {
    sync func repeat(c: Tensor, left: int): Tensor {
        return if left <= 0 then c else repeat(concat(c, col, 1), left - 1)
    }
    return repeat(col, k - 1)
}

func softmax(logits: Tensor): Tensor {
    let n = shape(logits)[0]
    let k = shape(logits)[1]
    let row_max = max(logits, 1)
    let row_max_2d = reshape(row_max, [n, 1])
    let row_max_broadcast = broadcast_col_to(row_max_2d, k)
    let stable = logits - row_max_broadcast
    let exp_logits = exp(stable)
    let row_sums = sum(exp_logits, 1)
    let row_sums_2d = reshape(row_sums, [n, 1])
    let row_sums_broadcast = broadcast_col_to(row_sums_2d, k)
    return exp_logits / row_sums_broadcast
}

func cross_entropy_loss(probs: Tensor, y_onehot: Tensor): float {
    let eps = 0.0000001
    let log_probs = log(probs + eps)
    let masked = y_onehot * log_probs
    return -sum(masked) / float(shape(probs)[0])
}

with <X: Tensor, y_onehot: Tensor, lr: float>
sync func update(W: Tensor): Tensor {
    let logits = X @ W
    let probs = softmax(logits)
    let m = shape(X)[0]
    let grad = transpose(X) @ (probs - y_onehot)
    return W - lr * (1.0 / float(m)) * grad
}

with <X: Tensor, y_onehot: Tensor, lr: float, its: int>
sync func train(W: Tensor): (Tensor, float[]) {
    sync func train_step(i: int, w: Tensor, loss_acc: float[]): (Tensor, float[]) {
        return if i >= its then (w, loss_acc) else sync {
            let nw = update<X, y_onehot, lr>(w)
            let new_acc = if i % 100 == 0 then {
                let probs_local = softmax(X @ nw)
                let loss_local = cross_entropy_loss(probs_local, y_onehot)
                'Iteration {}: Cross-Entropy Loss = {}'->format<i, loss_local>->println
                concat(loss_acc, [loss_local])
            } else {
                loss_acc
            }
            return train_step(i + 1, nw, new_acc)
        }
    }
    let empty_loss: float[] = []
    return train_step(0, W, empty_loss)
}

func main(): int sync {
    println('Loading MNIST via Python...')
    let mnist_mod = py_import("mnist_loader")
    let load_fn = py_attr(mnist_mod, "load_mnist")
    let data_py = py_call(load_fn, py_wrap(1000), py_wrap(true), py_wrap("tmp"))
    let data = py_unwrap(data_py as PyObject<{ images: float[], labels: int[], shape: int[] }>)

    let labels_arr = data.labels
    let n = data.shape[0]
    let d_in = data.shape[1]

    let X = reshape(data.images, [n, d_in])
    let ones_col = ones([n, 1])
    let X_bias = concat(X, ones_col, 1)
    let d = shape(X_bias)[1]

    sync func build_one_hot(i: int, acc: Tensor): Tensor {
        return if i >= n then acc else sync {
            let label_idx = labels_arr[i]
            let row = (range(0, 10) == label_idx) * 1.0
            let row_2d = reshape(row, [1, 10])
            let new_acc = if i == 0 then row_2d else concat(acc, row_2d, 0)
            return build_one_hot(i + 1, new_acc)
        }
    }

    let y_onehot = build_one_hot(0, zeros([1, num_classes]))
    var W = zeros([d, num_classes])
    let empty_loss: float[] = []
    var train_result = (W, empty_loss)

    let lr = 0.1
    let its = 300

    println('Training softmax classifier on MNIST...')
    println('Samples:', n, 'Features:', d_in, 'Classes:', num_classes)
    wait train_result = train<X_bias, y_onehot, lr, its>(W)
    let W_trained = train_result.0
    let loss_history = train_result.1

    let probs = softmax(X_bias @ W_trained)
    let loss = cross_entropy_loss(probs, y_onehot)
    'Final Cross-Entropy Loss: {}'->format<loss>->println

    let pred = argmax(X_bias @ W_trained, 1)
    let labels_t = argmax(y_onehot, 1)
    let correct = sum((pred == labels_t))
    let acc = correct / float(n)
    println(pred)
    println(labels_t)
    'Accuracy: {} / {} = {}'->format<correct, n, acc>->println

    var pred_list: int[] = []
    sync func collect_pred(i: int): void {
        return if i >= n then null else sync {
            pred_list->append<int(pred[i])>
            return collect_pred(i + 1)
        }
    }
    wait collect_pred(0)

    let viz_mod = py_import("mnist_viz")
    let viz_fn = py_attr(viz_mod, "visualize")
    py_call(viz_fn, py_wrap(loss_history), py_wrap(data.images), py_wrap(n), py_wrap(d_in),
            py_wrap(labels_arr), py_wrap(pred_list), py_wrap(true))
    return 0
}
