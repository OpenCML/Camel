module block_sort_merge

import { now } from time
import { seed, shuffle } from random
import { sort } from algo

func sort_block(arr: int[], lo: int, hi: int): int[] {
    var chunk = arr->slice<lo, hi>
    wait sort(chunk)
    return chunk
}

func main(): int sync {
    let blocks = 8
    let block_size = 5e5
    let n = blocks * block_size
    let preview = 16
    let s = 20260309

    seed(s)
    'Generating {} shuffled integers...'->format<n>->println
    let arr = range(0, n)->shuffle

    'Sorting {} independent blocks with {} items each...'->format<blocks, block_size>->println
    let start = now()

    let chunks = range(0, blocks)->map<(i: int): int[] => {
        let lo = i * block_size
        let hi = (i + 1) * block_size
        return sort_block(arr, lo, hi)
    }>
    let duration = now() - start
    println('Each block is sorted independently; unordered block boundaries shown below:')
    chunks->map<(chunk: int[]): int => chunk[0]>->println
    chunks->map<(chunk: int[]): int => chunk[block_size - 1]>->println
    'Block sorting completed in {:.2f} seconds'->format<duration>->println
    return 0
}
