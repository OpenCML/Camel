module asian_option_mc

import { now } from time
import { asian_call_price } from sim

func main(): int sync {
    let workers = 50
    let paths_per_worker = 2e5
    let steps = 256
    let base_seed = 20260309

    'Launching {} independent option-pricing workers...'->format<workers>->println
    'Paths per worker: {}, steps per path: {}'->format<paths_per_worker, steps>->println

    let start = now()
    let prices = range(0, workers)
        ->map<(i: int): float => asian_call_price(paths_per_worker, steps, base_seed + i * 7919)>
    let total = prices->reduce<(acc: float, cur: float): float => acc + cur, 0.0>
    let duration = now() - start
    let price = total / float(workers)

    'Worker prices (first 8 shown) = {}'->format<prices->slice<0, 8>>->println
    'Estimated Asian call price = {:.6f}'->format<price>->println
    'Asian option Monte Carlo completed in {:.2f} seconds'->format<duration>->println
    return 0
}
