module monte_carlo_pi

import { now } from time
import { pi_hits } from sim

func main(): int sync {
    let repeat = 50
    let samples_per_worker = 1e8
    let total_samples = repeat * samples_per_worker
    let base_seed = 0

    'Running {} times of Monte Carlo simulation...'->format<repeat>->println
    'Samples per simulation: {}, total samples: {}'->format<samples_per_worker, total_samples>->println

    let start = now()
    let total_hits = range(0, repeat)
        ->map<(i: int): int => pi_hits(samples_per_worker, base_seed + i * 7919)>
        ->reduce<(acc: int, cur: int): int => acc + cur, 0>
    let duration = now() - start
    let pi = 4.0 * float(total_hits) / float(total_samples)

    'Total hits = {}'->format<total_hits>->println
    'Estimated pi = {:.8f}'->format<pi>->println
    'Monte Carlo completed in {:.2f} seconds'->format<duration>->println

    return 0
}
