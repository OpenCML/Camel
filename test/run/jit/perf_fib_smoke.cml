/**
 * 意图：提供一个轻量性能 smoke，用于确认 JIT 跑 fib benchmark 时结果与计时接口正常。
 * 预期：打印 `jit perf fib(20): ...`；exit 0。
 */
module jit_perf_fib_smoke

import { perfms } from perf

func fib(n: int): int {
    return if n <= 1 then n else fib(n - 1) + fib(n - 2)
}

func main(): int sync {
    let warm = fib(20)
    if warm != 6765 then {
        return 1
    } else {
        let runs = 20
        let (average, margin_error) = perfms<runs>((): void => {
            fib(20)
        })

        'jit perf fib(20): {:.4f} +/- {:.4f} ms'->format<average, margin_error>->println

        if average < 0.0 then {
            return 2
        } else if margin_error < 0.0 then {
            return 3
        } else {
            return 0
        }
    }
}
