/**
 * 意图：验证 range/map/slice/concat 等列表变换在 JIT 下的正确性。
 * 预期：打印 `list_transform ok`；exit 0。
 */
module jit_list_transform

func main(): int sync {
    let xs = range(0, 8)
    let ys = xs->map<(x: int): int => {
        return x * x
    }>
    let zs = concat([100], ys->slice<2, 6>)

    if len(ys) != 8 then {
        return 1
    } else if ys[3] != 9 then {
        return 2
    } else if ys[7] != 49 then {
        return 3
    } else if len(zs) != 5 then {
        return 4
    } else if zs[0] != 100 then {
        return 5
    } else if zs[4] != 25 then {
        return 6
    } else {
        'list_transform ok'->println
        return 0
    }
}
