/**
 * 意图：验证 operator 返回值在 JIT 下继续参与后续分支、算术与返回时保持正确。
 * 预期：打印 `operator_branch_mix ok`；exit 0。
 */
module jit_operator_branch_mix

func pick(xs: int[]): int {
    let n = len(xs)
    let first = head(xs)
    return if n > 3 then first + n else first - n
}

func main(): int sync {
    let a = pick([4, 5, 6, 7])
    let b = pick([4, 5])

    if a != 8 then {
        return 1
    } else if b != 2 then {
        return 2
    } else {
        'operator_branch_mix ok'->println
        return 0
    }
}
