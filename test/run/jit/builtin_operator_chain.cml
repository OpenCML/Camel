/**
 * 意图：验证 len/contains/join/format 等内置 operator 链在 JIT 下的正确性，
 *       并覆盖 operator 结果继续参与分支与字符串比较的场景。
 * 预期：打印 `count=4 text=jit-ops-ok`；exit 0。
 */
module jit_builtin_operator_chain

func main(): int sync {
    let xs = [1, 2, 3, 4]
    let words = ['jit', 'ops', 'ok']
    let n = len(xs)
    let has3 = xs->contains<3>
    let text = words->join<'-'>
    let msg = 'count={} text={}'->format<n, text>

    if n != 4 then {
        return 1
    } else if has3 then sync {
        if text != 'jit-ops-ok' then {
            return 2
        } else if msg != 'count=4 text=jit-ops-ok' then {
            return 3
        } else {
            msg->println
            return 0
        }
    } else {
        return 4
    }
}
