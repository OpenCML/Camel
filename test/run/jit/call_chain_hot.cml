/**
 * 意图：验证多层函数调用链在 JIT 热路径下的正确性，覆盖频繁 call/ret 场景。
 * 预期：打印 `call_chain_hot ok`；exit 0。
 */
module jit_call_chain_hot

func inc(x: int): int {
    return x + 1
}

func twice(x: int): int {
    return inc(inc(x))
}

func sixfold(x: int): int {
    return twice(twice(twice(x)))
}

func repeat(n: int, acc: int): int {
    return if n == 0 then acc else repeat(n - 1, sixfold(acc))
}

func main(): int sync {
    let a = sixfold(1)
    let b = repeat(1000, 1)

    if a != 7 then {
        return 1
    } else if b != 6001 then {
        return 2
    } else {
        'call_chain_hot ok'->println
        return 0
    }
}
