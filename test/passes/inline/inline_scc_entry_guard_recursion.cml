/**
 * 覆盖点：
 * 1) SCC 内存在互递归（ping <-> pong）；
 * 2) `ping` 被 SCC 外（main）调用，属于 SCC 入口 callee；
 * 3) SCC 入口保护开启时，SCC 内对入口 `ping` 的调用不应被继续内联展开。
 *
 * 结构检查建议：
 * - `camel inline_scc_entry_guard_recursion.cml std::inline std::gir`
 * - 重点观察 SCC 内部是否仍保留对入口 `ping` 的 FUNC 调用（而不是被无限向内展开）。
 */
module inline_scc_entry_guard_recursion

func ping(n: int): int {
    return if n <= 0 then 0 else pong(n - 1)
}

func pong(n: int): int {
    return if n <= 0 then 0 else ping(n - 1)
}

func main(): int sync {
    let out = ping(6)
    if out != 0 then {
        return 1
    } else sync {
        'inline_scc_entry_guard_recursion ok'->println
        return 0
    }
}
