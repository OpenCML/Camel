module main

import {
    py_call,
    py_exec,
    py_eval,
    py_run,
    py_attr,
    py_import,
    to_py,
    from_py,
    PyObject
} from python

func main(): int sync {
    println("=== Python Integration Tests ===")

    // 1. py_call: 单标识符 -> builtins.print
    println("\n[1] py_call('print', to_py(1))")
    py_call("print", to_py(1))

    // 2. py_call: 显式路径 builtins.print
    println("\n[2] py_call('builtins.print', to_py('hello'))")
    py_call("builtins.print", to_py("hello"))

    // 3. py_call: 直接传 PyObject (通过 py_attr 获取 callable)
    println("\n[3] py_call via py_attr(builtins, 'print')")
    let builtins = py_import("builtins")
    let print_fn = py_attr(builtins, "print")
    py_call(print_fn, to_py("from py_attr"))

    // 4. py_call: len - 用 Python print 输出结果
    println("\n[4] py_call('len', to_py([1, 2, 3]))")
    let len_result = py_call("len", to_py([1, 2, 3]))
    py_call("print", py_call("str", len_result))

    // 5. py_eval: 表达式求值
    println("\n[5] py_eval('1 + 2 * 3')")
    let sum_result = py_eval("1 + 2 * 3") as PyObject<int>
    py_call("print", from_py(sum_result))

    println("\n[5b] py_eval(\"'hello' + ' world'\")")
    let str_result = py_eval("'hello' + ' world'")
    py_call("print", str_result)

    // 6. py_exec: 执行代码字符串
    println("\n[6] py_exec")
    py_exec("print('Exec: Hello from exec!')")

    // 7. py_run: 执行脚本文件
    println("\n[7] py_run('test/libs/python/hello.py')")
    py_run("test/libs/python/hello.py")

    // 8. py_attr: 链式访问 math.sqrt
    println("\n[8] py_attr(math, 'sqrt') -> math.sqrt(16)")
    let math_mod = py_import("math")
    let sqrt_fn = py_attr(math_mod, "sqrt")
    let sqrt_result = py_call(sqrt_fn, to_py(16))
    py_call("print", sqrt_result)

    println("\n=== All tests completed ===")
    return 0
}
