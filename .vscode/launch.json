{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "RUN",
            "cwd": "${workspaceFolder}",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/latest/bin/camel.exe",
            "symbolSearchPath": "${workspaceFolder}/out/latest/bin",
            "args": ["-v", "--log-level", "debug", "${file}"],
            "console": "externalTerminal",
            "logging": {
                "moduleLoad": true,
                "trace": true
            }
        },
        {
            "name": "Debugger (debug)",
            "cwd": "${workspaceFolder}",
